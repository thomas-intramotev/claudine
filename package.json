{
  "name": "claudine",
  "displayName": "Claudine",
  "description": "%extension.description%",
  "version": "1.1.3",
  "publisher": "claudine",
  "license": "MIT",
  "icon": "resources/icons/claudine-activitybar.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/salam/claudine"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/salam"
  },
  "homepage": "https://claudine.pro",
  "bugs": {
    "url": "https://github.com/salam/claudine/issues"
  },
  "keywords": [
    "kanban",
    "claude",
    "claude-code",
    "conversations",
    "project-management",
    "ai",
    "board"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "extensionDependencies": [],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudine.openKanban",
        "title": "%command.openKanban%",
        "category": "Claudine"
      },
      {
        "command": "claudine.refresh",
        "title": "%command.refresh%",
        "category": "Claudine",
        "icon": "$(refresh)"
      },
      {
        "command": "claudine.closeEmptyClaudeTabs",
        "title": "%command.closeEmptyClaudeTabs%",
        "category": "Claudine",
        "icon": "$(clear-all)"
      },
      {
        "command": "claudine.openConversation",
        "title": "%command.openConversation%",
        "category": "Claudine"
      },
      {
        "command": "claudine.searchConversations",
        "title": "%command.searchConversations%",
        "category": "Claudine"
      },
      {
        "command": "claudine.newConversation",
        "title": "%command.newConversation%",
        "category": "Claudine",
        "icon": "$(add)"
      },
      {
        "command": "claudine.moveConversation",
        "title": "%command.moveConversation%",
        "category": "Claudine"
      },
      {
        "command": "claudine.showNeedsInput",
        "title": "%command.showNeedsInput%",
        "category": "Claudine"
      },
      {
        "command": "claudine.showInProgress",
        "title": "%command.showInProgress%",
        "category": "Claudine"
      },
      {
        "command": "claudine.archiveDone",
        "title": "%command.archiveDone%",
        "category": "Claudine"
      },
      {
        "command": "claudine.toggleSummarization",
        "title": "%command.toggleSummarization%",
        "category": "Claudine",
        "icon": "$(sparkle)"
      },
      {
        "command": "claudine.regenerateIcons",
        "title": "%command.regenerateIcons%",
        "category": "Claudine"
      },
      {
        "command": "claudine.openSettings",
        "title": "%command.openSettings%",
        "category": "Claudine"
      },
      {
        "command": "claudine.focusClaude",
        "title": "%command.focusClaude%",
        "category": "Claudine"
      },
      {
        "command": "claudine.exportBoard",
        "title": "%command.exportBoard%",
        "category": "Claudine"
      },
      {
        "command": "claudine.importBoard",
        "title": "%command.importBoard%",
        "category": "Claudine"
      },
      {
        "command": "claudine.showDiagnostics",
        "title": "%command.showDiagnostics%",
        "category": "Claudine"
      },
      {
        "command": "claudine.toggleSearch",
        "title": "%command.toggleSearch%",
        "category": "Claudine",
        "icon": "$(search)"
      },
      {
        "command": "claudine.toggleFilter",
        "title": "%command.toggleFilter%",
        "category": "Claudine",
        "icon": "$(filter)"
      },
      {
        "command": "claudine.toggleCompactView",
        "title": "%command.toggleCompactView%",
        "category": "Claudine",
        "icon": "$(list-flat)"
      },
      {
        "command": "claudine.toggleExpandAll",
        "title": "%command.toggleExpandAll%",
        "category": "Claudine",
        "icon": "$(expand-all)"
      },
      {
        "command": "claudine.toggleArchive",
        "title": "%command.toggleArchive%",
        "category": "Claudine",
        "icon": "$(archive)"
      },
      {
        "command": "claudine.zoomIn",
        "title": "%command.zoomIn%",
        "category": "Claudine",
        "icon": "$(zoom-in)"
      },
      {
        "command": "claudine.zoomOut",
        "title": "%command.zoomOut%",
        "category": "Claudine",
        "icon": "$(zoom-out)"
      },
      {
        "command": "claudine.zoomReset",
        "title": "%command.zoomReset%",
        "category": "Claudine",
        "icon": "$(screen-normal)"
      },
      {
        "command": "claudine.toggleSettingsPanel",
        "title": "%command.toggleSettingsPanel%",
        "category": "Claudine",
        "icon": "$(gear)"
      },
      {
        "command": "claudine.toggleAbout",
        "title": "%command.toggleAbout%",
        "category": "Claudine",
        "icon": "$(info)"
      },
      {
        "command": "claudine.setupAgentIntegration",
        "title": "%command.setupAgentIntegration%",
        "category": "Claudine",
        "icon": "$(plug)"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "claudine-panel",
          "title": "%viewContainer.panel.title%",
          "icon": "resources/icons/claudine-activitybar3.svg"
        }
      ]
    },
    "views": {
      "claudine-panel": [
        {
          "type": "webview",
          "id": "claudine.kanbanView",
          "name": "%view.panel.name%"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "claudine.imageGenerationApi": {
          "type": "string",
          "enum": [
            "openai",
            "stability",
            "none"
          ],
          "default": "none",
          "description": "%config.imageGenerationApi.description%"
        },
        "claudine.claudeCodePath": {
          "type": "string",
          "default": "~/.claude",
          "description": "%config.claudeCodePath.description%"
        },
        "claudine.codexPath": {
          "type": "string",
          "default": "~/.codex",
          "description": "%config.codexPath.description%"
        },
        "claudine.enableSummarization": {
          "type": "boolean",
          "default": false,
          "description": "%config.enableSummarization.description%"
        },
        "claudine.toolbarLocation": {
          "type": "string",
          "enum": [
            "sidebar",
            "titlebar"
          ],
          "default": "sidebar",
          "description": "%config.toolbarLocation.description%"
        },
        "claudine.autoRestartAfterRateLimit": {
          "type": "boolean",
          "default": false,
          "description": "%config.autoRestartAfterRateLimit.description%"
        },
        "claudine.showTaskIcon": {
          "type": "boolean",
          "default": true,
          "description": "%config.showTaskIcon.description%"
        },
        "claudine.showTaskDescription": {
          "type": "boolean",
          "default": true,
          "description": "%config.showTaskDescription.description%"
        },
        "claudine.showTaskLatest": {
          "type": "boolean",
          "default": true,
          "description": "%config.showTaskLatest.description%"
        },
        "claudine.showTaskGitBranch": {
          "type": "boolean",
          "default": true,
          "description": "%config.showTaskGitBranch.description%"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "claudine.toggleSearch",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@1"
        },
        {
          "command": "claudine.toggleFilter",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@2"
        },
        {
          "command": "claudine.toggleCompactView",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@3"
        },
        {
          "command": "claudine.toggleExpandAll",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@4"
        },
        {
          "command": "claudine.toggleSummarization",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@5"
        },
        {
          "command": "claudine.refresh",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@6"
        },
        {
          "command": "claudine.closeEmptyClaudeTabs",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@7"
        },
        {
          "command": "claudine.toggleArchive",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@8"
        },
        {
          "command": "claudine.zoomOut",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@9"
        },
        {
          "command": "claudine.zoomReset",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@10"
        },
        {
          "command": "claudine.zoomIn",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@11"
        },
        {
          "command": "claudine.toggleSettingsPanel",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@12"
        },
        {
          "command": "claudine.toggleAbout",
          "when": "(view == claudine.kanbanView) && config.claudine.toolbarLocation != 'sidebar'",
          "group": "navigation@13"
        }
      ]
    },
    "keybindings": [
      {
        "command": "claudine.openKanban",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      },
      {
        "command": "claudine.refresh",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "claudine.kanbanView.visible"
      },
      {
        "command": "claudine.searchConversations",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "claudine.kanbanView.visible"
      },
      {
        "command": "claudine.newConversation",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "claudine.kanbanView.visible"
      },
      {
        "command": "claudine.showNeedsInput",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "claudine.kanbanView.visible"
      },
      {
        "command": "claudine.focusClaude",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c"
      }
    ],
    "walkthroughs": [
      {
        "id": "claudine.gettingStarted",
        "title": "%walkthrough.gettingStarted.title%",
        "description": "%walkthrough.gettingStarted.description%",
        "steps": [
          {
            "id": "claudine.walkthrough.installClaude",
            "title": "%walkthrough.installClaude.title%",
            "description": "%walkthrough.installClaude.description%",
            "media": {
              "markdown": "resources/walkthrough/install-claude.md"
            },
            "completionEvents": [
              "extensionInstalled:anthropic.claude-code"
            ]
          },
          {
            "id": "claudine.walkthrough.findBoard",
            "title": "%walkthrough.findBoard.title%",
            "description": "%walkthrough.findBoard.description%",
            "media": {
              "markdown": "resources/walkthrough/find-board.md"
            },
            "completionEvents": [
              "onCommand:claudine.openKanban"
            ]
          },
          {
            "id": "claudine.walkthrough.startConversation",
            "title": "%walkthrough.startConversation.title%",
            "description": "%walkthrough.startConversation.description%",
            "media": {
              "markdown": "resources/walkthrough/start-conversation.md"
            },
            "completionEvents": [
              "onCommand:claudine.newConversation"
            ]
          },
          {
            "id": "claudine.walkthrough.keyFeatures",
            "title": "%walkthrough.keyFeatures.title%",
            "description": "%walkthrough.keyFeatures.description%",
            "media": {
              "markdown": "resources/walkthrough/key-features.md"
            },
            "completionEvents": [
              "onCommand:claudine.searchConversations"
            ]
          },
          {
            "id": "claudine.walkthrough.agentIntegration",
            "title": "%walkthrough.agentIntegration.title%",
            "description": "%walkthrough.agentIntegration.description%",
            "media": {
              "markdown": "resources/walkthrough/agent-integration.md"
            },
            "completionEvents": [
              "onCommand:claudine.setupAgentIntegration"
            ]
          }
        ]
      }
    ]
  },
  "bin": {
    "claudine": "./out-standalone/claudine.js"
  },
  "scripts": {
    "vscode:prepublish": "npm run package && npm run build:webview",
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production",
    "compile:check": "tsc -p ./ --noEmit",
    "build:webview": "cd webview && npm run build",
    "dev:webview": "cd webview && npm run dev",
    "build:standalone": "node esbuild-standalone.mjs",
    "standalone": "node esbuild-standalone.mjs && node out-standalone/claudine.js standalone",
    "dev:standalone": "node esbuild-standalone.mjs --watch",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
