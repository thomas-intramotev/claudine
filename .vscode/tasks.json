{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "isBackground": false,
      "presentation": {
        "reveal": "silent"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "silent"
      },
      "group": "build"
    },
    {
      "label": "Build Webview",
      "type": "shell",
      "command": "cd webview && npm run build",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Dev Webview",
      "type": "shell",
      "command": "cd webview && npm run dev",
      "problemMatcher": [],
      "isBackground": true,
      "group": "build"
    }
  ]
}
