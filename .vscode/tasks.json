{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "isBackground": false,
      "presentation": {
        "reveal": "silent"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "silent"
      },
      "group": "build"
    },
    {
      "label": "Build Webview",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/webview"
      },
      "command": "npm run build",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Dev Webview",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/webview"
      },
      "command": "npm run dev",
      "problemMatcher": [],
      "isBackground": true,
      "group": "build"
    },
    {
      "label": "Build Standalone + Webview",
      "dependsOn": ["npm: build:standalone", "Build Webview"],
      "dependsOrder": "parallel",
      "group": "build"
    }
  ]
}
